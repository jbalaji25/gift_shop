{
    "name": "wudden-interior-monorepo",
    "private": true,
    "version": "1.0.0",
    "description": "Monorepo for Wudden Interior Gift Shop - Frontend & Backend",
    "scripts": {
        "install:all": "npm install --prefix frontend && npm install --prefix backend",
        "dev:frontend": "npm run dev --prefix frontend",
        "dev:backend": "npm run dev --prefix backend",
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "build:frontend": "npm run build --prefix frontend",
        "lint:frontend": "npm run lint --prefix frontend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}